---
/**
 * Landing page (`/`) — Astro replica of the prototype `landing-static.html`.
 *
 * The prototype DOM, classes, and section order are reproduced verbatim. Only
 * the following are adapted for Astro + GitHub Pages base-path safety:
 *   - the topbar markup is extracted into `Topbar.astro` (same DOM/classes);
 *   - the inline `<style>` block is loaded from `styles/prototype/landing.css`
 *     (extracted verbatim in Task 2) plus shared `tokens.css`;
 *   - `logo.png` is a bundled asset import;
 *   - prototype `.html` links are rewritten to real routes through
 *     `import.meta.env.BASE_URL`;
 *   - `theme.js` and `landing.js` are bundled via Vite-processed `<script>`
 *     imports so generated SVGs, tabs, copy, reveals, and theme toggle work.
 *
 * Interaction hooks the ported scripts depend on are preserved exactly:
 *   #heroDiagram, #capGrid, #howTabs / #howCanvas, #dslCode / #dslNotes,
 *   .reveal, .how-tab[data-step], [data-copy], [data-theme-set].
 */
import Topbar from '../components/prototype/Topbar.astro';
import logo from '../assets/prototype/logo.png';
import { normalizeBaseUrl, withBaseUrl } from '../utils/base-url';
import '../styles/prototype/tokens.css';
import '../styles/prototype/landing.css';

const base = normalizeBaseUrl(import.meta.env.BASE_URL);
const docsHref = withBaseUrl(base, 'docs/');
// Footer "Workflows" link targets the canonical docs article at its final
// route, not the docs home. All links are final-route based and joined to
// BASE_URL so they resolve from `/` or any sub-path.
const articleHref = withBaseUrl(base, 'docs/workflows/');
const homeHref = base;
const designSystemHref = withBaseUrl(base, 'design-system/');
const githubHref = 'https://github.com/weave-io/weave';
const quickstartHref = withBaseUrl(base, 'docs/getting-started/');
const referenceHref = withBaseUrl(base, 'docs/reference/cli/');

// Page description — preserved as document metadata for the landing route
// (custom Astro page, so it is owned here rather than by Starlight's Head).
const description =
  'A single .weave file describes prompts, agents, workflows, model preferences, and policy once. Weave validates that config, composes prompts, and materializes the current implementation in OpenCode.';

// Verbatim inner HTML of the prototype's `#dslCode` <pre> (landing-static.html
// line 265). Rendered via `set:html` so Astro does not interpret the literal
// `{`/`}` punctuation tokens as JSX expression delimiters — they must survive
// as `<span class="pn">{</span>` to match the prototype exactly.
const currentDslCode = [
  '<span class="l"><span class="cm"># .weave/config.weave — current v0.4 surface</span></span>',
  '<span class="l"><span class="kw">agent</span> <span class="id">reviewer</span> <span class="pn">{</span></span>',
  '<span class="l">  <span class="kw">description</span> <span class="str">"Review docs changes"</span></span>',
  '<span class="l">  <span class="kw">prompt_file</span> <span class="str">"reviewer.md"</span></span>',
  '<span class="l">  <span class="kw">models</span> <span class="pn">[</span><span class="str">"claude-sonnet-4-5"</span><span class="pn">]</span></span>',
  '<span class="l">  <span class="kw">mode</span> <span class="id">subagent</span></span>',
  '<span class="l"><span class="pn">}</span></span>',
  '<span class="l"></span>',
  '<span class="l"><span class="kw">category</span> <span class="id">frontend</span> <span class="pn">{</span></span>',
  '<span class="l">  <span class="kw">description</span> <span class="str">"UI, UX, styling"</span></span>',
  '<span class="l">  <span class="kw">patterns</span> <span class="pn">[</span><span class="str">"src/components/**"</span><span class="pn">,</span> <span class="str">"**/*.tsx"</span><span class="pn">]</span></span>',
  '<span class="l">  <span class="kw">prompt_append</span> <span class="str">"Preserve accessibility."</span></span>',
  '<span class="l"><span class="pn">}</span></span>',
  '<span class="l"></span>',
  '<span class="l"><span class="kw">workflow</span> <span class="id">review-docs</span> <span class="pn">{</span></span>',
  '<span class="l">  <span class="kw">description</span> <span class="str">"Review public documentation"</span></span>',
  '<span class="l">  <span class="kw">version</span> <span class="id">1</span></span>',
  '<span class="l">  <span class="kw">step</span> <span class="id">review</span> <span class="pn">{</span></span>',
  '<span class="l">    <span class="kw">name</span> <span class="str">"Review the docs"</span></span>',
  '<span class="l">    <span class="kw">type</span> <span class="id">gate</span></span>',
  '<span class="l">    <span class="kw">agent</span> <span class="id">reviewer</span></span>',
  '<span class="l">    <span class="kw">prompt</span> <span class="str">"Check accuracy before publishing."</span></span>',
  '<span class="l">    <span class="kw">completion</span> <span class="id">review_verdict</span></span>',
  '<span class="l">    <span class="kw">on_reject</span> <span class="id">pause</span></span>',
  '<span class="l">  <span class="pn">}</span></span>',
  '<span class="l"><span class="pn">}</span></span>',
].join('');
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Weave — orchestrate agents in a language they share</title>
    <meta name="description" content={description} />
    <link rel="icon" href={logo.src} />
  </head>
  <body data-screen-label="Landing">
    <Topbar />

    <!-- HERO -->
    <section class="hero">
      <div class="bg"></div>
      <div class="wrap inner">
        <div class="eyebrow">
          <span class="pill">v0.4.7</span>
          <span class="ann">multi-agent · dsl · harness-agnostic</span>
        </div>
        <h1>Orchestrate agents in a <span class="b">language</span> <span class="d">they share.</span></h1>
        <p class="lede">A single <code>.weave</code> file declares agents, category shuttles, workflows, model preferences and tool policy. Today Weave materializes that intent in OpenCode and gives you CLI tools to validate configs and inspect composed prompts before a harness uses them.</p>
        <div class="ctas">
          <a class="w-btn primary lg" href={docsHref}>Read the docs</a>
          <a class="w-btn lg" href="#dsl">Explore the DSL</a>
          <a class="w-btn ghost lg" href="#architecture">See architecture</a>
        </div>
        <div class="hero-meta">DSL-first config · implemented OpenCode adapter · Bun-only TypeScript packages <span class="dot"></span> MIT</div>

        <!-- HERO DIAGRAM -->
        <div class="editor reveal">
          <div class="editor-head">
            <span class="tabs">
              <span class="tab active">config.weave</span>
              <span class="tab">prompts/</span>
              <span class="tab">OpenCode</span>
            </span>
            <span class="spacer"></span>
            <span>validate · inspect · materialize</span>
          </div>
          <div class="editor-body" id="heroDiagram"></div>
        </div>
      </div>
    </section>

    <!-- WHY -->
    <section class="section" id="why">
      <div class="wrap reveal">
        <span class="kicker">why weave</span>
        <h2>Agent tooling fragments. Intent shouldn’t.</h2>
        <div class="duo">
          <div class="col problem">
            <h3>The problem</h3>
            <ul>
              <li>Prompts are shaped to one vendor’s harness and rot when you switch.</li>
              <li>Delegation between agents is implicit, undocumented, unverifiable.</li>
              <li>Prompt files, model lists and policy drift across repos.</li>
              <li>Harness setup mixes durable intent with local runtime details.</li>
            </ul>
          </div>
          <div class="col solution">
            <h3>The Weave solution</h3>
            <ul>
              <li>One DSL describes agents, categories, workflows, skills and policy.</li>
              <li>The parser and schema produce a typed, normalized config.</li>
              <li>A one-way adapter boundary keeps core harness-agnostic.</li>
              <li>Model lists remain adapter-facing preferences, not direct execution.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CAPABILITIES -->
    <section class="section" id="capabilities">
      <div class="wrap reveal">
        <span class="kicker">capabilities</span>
        <h2>Implemented primitives. One coherent model.</h2>
        <div class="cap-grid" id="capGrid"></div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section" id="how">
      <div class="wrap reveal">
        <span class="kicker">how it works</span>
        <h2>Define → Validate → Compose → Materialize → Use in OpenCode.</h2>
        <div class="how">
          <div class="how-tabs" id="howTabs">
            <button class="how-tab active" data-step="define">define</button>
            <button class="how-tab" data-step="validate">validate</button>
            <button class="how-tab" data-step="compose">compose</button>
            <button class="how-tab" data-step="materialize">materialize</button>
            <button class="how-tab" data-step="use">use</button>
          </div>
          <div class="how-canvas" id="howCanvas"></div>
        </div>
      </div>
    </section>

    <!-- DSL -->
    <section class="section" id="dsl">
      <div class="wrap reveal">
        <span class="kicker">the dsl</span>
        <h2>Real config syntax, not aspirational pseudocode.</h2>
        <div class="dsl">
          <div class="editor">
            <div class="editor-head">
              <span class="fdot" style="width:8px;height:8px;border-radius:50%;background:var(--tertiary)"></span>
              <span style="color:var(--text-2)">config.weave</span>
              <span class="spacer"></span>
              <button class="copy-btn" data-copy="#dslCode">copy</button>
            </div>
<pre id="dslCode" set:html={currentDslCode}></pre>
          </div>
          <div class="dsl-notes" id="dslNotes"></div>
        </div>
      </div>
    </section>

    <!-- ARCHITECTURE -->
    <section class="section" id="architecture">
      <div class="wrap reveal">
        <span class="kicker">architecture</span>
        <h2>A one-way boundary between intent and harness.</h2>
        <div class="arch">
          <div class="col left core">
            <h3>core · harness-agnostic</h3>
            <ul>
              <li>parser</li>
              <li>schema validation</li>
              <li>config merge</li>
              <li>prompt composition</li>
              <li>runtime journal</li>
            </ul>
            <p class="rule"><b>MUST NOT</b> import adapter code or read harness config.</p>
          </div>
          <div class="col right">
            <h3 style="color:var(--secondary-2)">adapters · per-harness</h3>
            <ul>
              <li><span class="d2"></span> opencode · implemented</li>
              <li><span class="d2"></span> claude-code · placeholder</li>
              <li><span class="d2"></span> pi · placeholder</li>
              <li><span class="d2"></span> adapter experiments · external</li>
            </ul>
            <p class="rule"><b>MAY</b> add capabilities · <b>MUST NOT</b> mutate normalized intent.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- DOCS CTA -->
    <section class="section" id="docs">
      <div class="wrap reveal">
        <span class="kicker">documentation</span>
        <h2>Docs treated as a first-class surface.</h2>
        <div class="docs-cta">
          <div class="card">
            <p>The public docs now follow the working product: author <code>.weave</code>, validate it, inspect composed prompts, install the OpenCode plugin, and inspect runtime state. Future adapter ideas are marked separately from implemented behavior.</p>
            <div class="row">
              <a class="w-btn primary" href={docsHref}>Open the docs</a>
              <a class="w-btn" href={articleHref}>View an article</a>
            </div>
          </div>
          <div class="docs-tree">
            <div class="t"><span class="n">01</span> Getting started</div>
            <div class="t"><span class="n">02</span> Core concepts</div>
            <div class="t"><span class="n">03</span> Configuration</div>
            <div class="t"><span class="n">04</span> Agents & categories</div>
            <div class="t cur"><span class="n">05</span> Prompts, models & policy</div>
            <div class="t"><span class="n">06</span> Workflows</div>
            <div class="t"><span class="n">07</span> OpenCode adapter</div>
            <div class="t"><span class="n">08</span> Runtime operations</div>
            <div class="t"><span class="n">09</span> CLI reference</div>
            <div class="t"><span class="n">10</span> DSL reference</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final w-gridbg">
      <div class="wrap reveal">
        <span class="tag">v0.4.7 · current docs</span>
        <h2>Stop authoring prompts. Author <span class="b">intent</span>.</h2>
        <p>MIT-licensed and small enough to inspect. Configure once; materialize accurately in OpenCode today while the core stays ready for future harness adapters.</p>
        <div class="ctas">
          <a class="w-btn primary lg" href={docsHref}>Read the docs</a>
          <a class="w-btn lg" href="#dsl">Explore the DSL</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="foot">
      <div class="wrap">
        <div class="foot-grid">
          <div class="foot-brand">
            <div class="word"><img src={logo.src} alt="" style="width:24px;height:24px;border-radius:4px" /> weave</div>
            <p>A harness-agnostic prompt and agent-configuration framework for infrastructure people.</p>
          </div>
          <div>
            <h4>Product</h4>
            <ul>
              <li><a href="#capabilities">Capabilities</a></li>
              <li><a href="#dsl">The DSL</a></li>
              <li><a href="#architecture">Architecture</a></li>
              <li><a href={designSystemHref}>Design system</a></li>
            </ul>
          </div>
          <div>
            <h4>Docs</h4>
            <ul>
              <li><a href={docsHref}>Introduction</a></li>
              <li><a href={articleHref}>Workflows</a></li>
              <li><a href={quickstartHref}>Quickstart</a></li>
              <li><a href={referenceHref}>Reference</a></li>
            </ul>
          </div>
          <div>
            <h4>Project</h4>
            <ul>
              <li><a href={githubHref}>GitHub ↗</a></li>
              <li><a href={githubHref}>Changelog</a></li>
              <li><a href={githubHref}>License · MIT</a></li>
              <li><a href={homeHref}>Design package</a></li>
            </ul>
          </div>
        </div>
        <div class="foot-meta">weave · v0.4.7 · 2026 — made for infrastructure people</div>
      </div>
    </footer>

    <script>
      import '../scripts/prototype/theme.js';
      import '../scripts/prototype/landing.js';
    </script>
  </body>
</html>
