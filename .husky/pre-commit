#!/usr/bin/env bash
set -euo pipefail

echo "▶ lint-staged..."
bunx lint-staged

echo "▶ typecheck..."
bun run typecheck

echo "▶ validate-config..."
bun run validate-config

echo "▶ validate-fixture..."
bun run scripts/validate-config.ts scripts/fixtures/full-config.weave

echo "▶ test..."
bun test --recursive

echo "▶ codesight..."
npx codesight
git add .codesight/

echo "✔ all checks passed"
