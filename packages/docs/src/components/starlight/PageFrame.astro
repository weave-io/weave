---
/**
 * PageFrame override — the structural heart of the docs hard-override.
 *
 * Starlight composes the docs page as
 *   PageFrame[ header=Header, sidebar=Sidebar, default=TwoColumnContent[...] ]
 * (see Starlight's `Page.astro`). Rather than theme Starlight's default
 * `.page` / `.header` / `.sidebar-pane` shell, this override rebuilds the
 * prototype docs shell verbatim:
 *
 *   header.w-topbar              ← prototype docs topbar (brand + nav + theme)
 *   div.docs-shell               ← prototype 3-column grid (docs.css)
 *     aside.sidebar              ← #searchTrigger search box + <slot name="sidebar">
 *     <slot/>                    ← TwoColumnContent → .docs-main + .toc
 *   div#palette                  ← command-palette overlay (behavior in docs.js)
 *
 * The default Starlight `Header` override renders nothing, so the
 * `<slot name="header" />` is intentionally dropped here — the prototype
 * topbar is the only header. The `sidebar` slot carries the prototype
 * `.nav-group` markup produced by the `Sidebar` override.
 *
 * Base-path safety: the brand logo is a bundled asset import; every internal
 * link is routed through `import.meta.env.BASE_URL` so it resolves whether the
 * site is served from `/` or any sub-path on GitHub Pages. `theme.js` /
 * `docs.js` are imported as Vite `<script>` modules (not raw URLs).
 *
 * The `#searchTrigger` / `#palette` / `#paletteInput` / `#paletteResults`
 * markup is the interaction contract `docs.js` binds to. The palette result
 * data and styling are filled in by later tasks; the structural hooks must
 * exist now so those tasks have a stable shell to attach to.
 */
import logo from '../../assets/prototype/logo.png';
import ThemeToggle from '../prototype/ThemeToggle.astro';
import { docsSearchData } from '../../data/docs-search';
import { normalizeBaseUrl, withBaseUrl } from '../../utils/base-url';

const { hasSidebar } = Astro.locals.starlightRoute;

const base = normalizeBaseUrl(import.meta.env.BASE_URL);
const homeHref = base;
const docsHref = withBaseUrl(base, 'docs/');
const designSystemHref = withBaseUrl(base, 'design-system/');
const githubHref = 'https://github.com/weave-io/weave';

// Command-palette data, base-path-resolved. `docs-search.ts` stores raw
// root-relative hrefs (e.g. `docs/workflows/#overview`); here we join each to
// `BASE_URL` so the palette navigates to the correct deployed URL regardless of
// `base`. The resolved array is serialized into a `<script id="paletteData">`
// JSON block inside the palette, which `docs.js` reads at runtime (falling back
// to its built-in defaults if the element is missing). This keeps the search
// data declarative and base-aware while leaving palette behavior in docs.js.
const paletteEntries = docsSearchData.map((entry) => ({
  g: entry.group,
  t: entry.title,
  s: entry.subtitle,
  href: withBaseUrl(base, entry.href),
  ic: entry.icon,
}));
const paletteJson = JSON.stringify(paletteEntries);
---

<header class="w-topbar">
  <a class="brand" href={homeHref}>
    <img src={logo.src} alt="Weave" />
    <span class="word">weave <span class="sub">/ docs</span></span>
  </a>
  <nav class="main">
    <a href={docsHref}>Documentation</a>
    <a href={designSystemHref}>Design system</a>
  </nav>
  <span class="spacer"></span>
  <ThemeToggle />
  <a class="w-btn ghost" href={githubHref}>GitHub ↗</a>
</header>

<div class="docs-shell">
  {
    hasSidebar && (
      <aside class="sidebar">
        <button class="search" id="searchTrigger" type="button" aria-label="Search documentation">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m20 20-3.5-3.5"></path>
          </svg>
          <span class="ph">Search</span>
          <span class="keys"><kbd>⌘</kbd><kbd>K</kbd></span>
        </button>
        <slot name="sidebar" />
      </aside>
    )
  }

  <slot />
</div>

{/* Command-palette overlay. Behavior (open/filter/navigate) lives in docs.js;
    the markup mirrors the prototype `docs-home.html` / `docs-article.html`
    palette exactly: a `.palette-backdrop` (#palette) holding a `.palette` box
    with a `.pin` search row (magnifier icon + input), a `.results` list, and a
    `.pfoot` keyboard-hint footer. docs.js binds to the `#palette`,
    `#paletteInput`, and `#paletteResults` ids and renders `.grp` / `.res` rows
    into the results container. */}
<div id="palette" class="palette-backdrop" role="dialog" aria-modal="true" aria-label="Search docs">
  {/* Real-route search data (base-path-resolved). docs.js parses this JSON to
      populate palette results; if absent it falls back to its defaults. */}
  <script is:inline id="paletteData" type="application/json" set:html={paletteJson}></script>
  <div class="palette">
    <div class="pin">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><path d="M20 20l-3.5-3.5"></path></svg>
      <input id="paletteInput" type="text" placeholder="Search pages, specs, ADRs…" autocomplete="off" spellcheck="false" />
    </div>
    <div id="paletteResults" class="results"></div>
    <div class="pfoot">
      <span class="k"><span class="w-kbd">↑</span><span class="w-kbd">↓</span> navigate</span>
      <span class="k"><span class="w-kbd">↵</span> open</span>
      <span class="k"><span class="w-kbd">esc</span> close</span>
    </div>
  </div>
</div>

<script>
  import '../../scripts/prototype/theme.js';
  import '../../scripts/prototype/docs.js';
</script>
