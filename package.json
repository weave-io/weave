{
  "name": "@weaveio/weave",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/engine",
    "packages/config",
    "packages/cli",
    "packages/docs",
    "packages/adapters/*"
  ],
  "scripts": {
    "changeset": "changeset",
    "docs:dev": "bun run --filter '@weaveio/weave-docs' dev",
    "docs:build": "bun run --filter '@weaveio/weave-docs' build",
    "docs:preview": "bun run --filter '@weaveio/weave-docs' preview",
    "validate-config": "bun packages/cli/src/main.ts validate --project",
    "build": "bun run --filter '@weaveio/weave-core' build && bun run --filter '@weaveio/weave-engine' --filter '@weaveio/weave-config' build && bun run --filter '@weaveio/weave-cli' build && bun run --filter '@weaveio/weave-adapter-*' build && bun run --filter '@weaveio/weave-docs' build",
    "test": "bun run --filter '*' test",
    "typecheck": "tsc --noEmit -p tsconfig.json && bun run --filter '*' typecheck",
    "lint": "biome lint packages/",
    "clean": "find . -type d -name dist -not -path '*/node_modules/*' | xargs rm -rf",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@changesets/cli": "^2.31.0",
    "bun-types": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/weave-io/weave"
  }
}