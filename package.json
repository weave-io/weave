{
  "name": "@weave",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/engine",
    "packages/config",
    "packages/cli",
    "packages/adapters/*"
  ],
  "scripts": {
    "validate-config": "bun packages/cli/src/main.ts validate --project",
    "build": "bun run --filter '@weave/core' build && bun run --filter '@weave/engine' --filter '@weave/config' build && bun run --filter '@weave/cli' build && bun run --filter '@weave/adapter-*' build",
    "test": "bun run --filter '*' test",
    "typecheck": "tsc --noEmit -p tsconfig.json && bun run --filter '*' typecheck",
    "lint": "biome lint packages/",
    "clean": "find . -type d -name dist -not -path '*/node_modules/*' | xargs rm -rf",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "bun-types": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
