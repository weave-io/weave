{
  "name": "@weave/adapter-opencode",
  "version": "0.0.1",
  "description": "OpenCode plugin adapter for the Weave orchestration framework",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opencode-ai/plugin": "~1.15.9",
    "@opencode-ai/sdk": "~1.15.9",
    "@weave/config": "workspace:*",
    "@weave/core": "workspace:*",
    "@weave/engine": "workspace:*",
    "neverthrow": "^8.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
