{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@weaveio/weave-core": ["./packages/core/src/index.ts"],
      "@weaveio/weave-core/*": ["./packages/core/src/*"],
      "@weaveio/weave-engine": ["./packages/engine/src/index.ts"],
      "@weaveio/weave-engine/*": ["./packages/engine/src/*"],
      "@weaveio/weave-adapter-opencode": ["./packages/adapters/opencode/src/index.ts"],
      "@weaveio/weave-adapter-claude-code": ["./packages/adapters/claude-code/src/index.ts"],
      "@weaveio/weave-adapter-pi": ["./packages/adapters/pi/src/index.ts"],
      "@weaveio/weave-config": ["./packages/config/src/index.ts"],
      "@weaveio/weave-config/*": ["./packages/config/src/*"],
      "@weaveio/weave-cli": ["./packages/cli/src/index.ts"],
      "@weaveio/weave-cli/*": ["./packages/cli/src/*"]
    }
  },
  "include": [
    "types/**/*",
    "packages/*/src/**/*",
    "packages/adapters/*/src/**/*",
    "scripts/**/*"
  ],
  "exclude": ["node_modules", "**/dist/**"]
}
