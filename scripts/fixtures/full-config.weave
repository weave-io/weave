# scripts/fixtures/full-config.weave
#
# Comprehensive fixture that exercises every supported DSL feature.
# Parsed on every commit to guard against regressions in the core pipeline.
#
# Run manually:  bun run validate-config scripts/fixtures/full-config.weave

# ===========================================================================
# Agents — all fields, all mode values, both prompt forms, all permissions
# ===========================================================================

# mode primary · inline prompt · all tool_policy keys · all three permissions
# · multiple models · triggers · skills
agent orchestrator {
  description "Primary orchestrator — all agent fields exercised"
  prompt "You are the orchestrator."
  models ["claude-sonnet-4-5", "gpt-4o", "gemini-pro"]
  mode primary
  temperature 0.1

  tool_policy {
    read     allow
    write    allow
    edit     allow
    delegate allow
    search   ask
  }

  triggers [
    { domain "Orchestration" trigger "Complex multi-step tasks requiring coordination" }
    { domain "Architecture"  trigger "System design and cross-cutting decisions"       }
    { domain "Triage"        trigger "Unclear requests that need decomposition"        }
  ]

  skills ["tdd", "code-review"]
}

# mode subagent · prompt_file · deny permissions · single trigger · single skill
agent specialist {
  description "Subagent backed by a prompt file"
  prompt_file "specialist.md"
  models ["claude-sonnet-4-5"]
  mode subagent
  temperature 0.3

  tool_policy {
    read     allow
    write    deny
    edit     deny
    delegate deny
    search   allow
  }

  triggers [
    { domain "Research" trigger "Fetching external documentation or prior art" }
  ]

  skills ["tdd"]
}

# mode all · ask permission · temperature at upper bound
agent hybrid {
  description "Agent in all modes — ask permission exercised"
  prompt "You operate in all modes."
  models ["gpt-4o"]
  mode all
  temperature 2.0

  tool_policy {
    read  allow
    write ask
    edit  ask
  }
}

# Bare minimum — only required fields
agent bare {
  prompt "Minimal agent with only required fields."
  models ["claude-sonnet-4-5"]
}

# ===========================================================================
# Categories — all fields, minimal variant
# ===========================================================================

# All category fields including prompt_append and multiple patterns
category full-cat {
  description "Category with every field set"
  models ["claude-sonnet-4-5", "gpt-4o"]
  patterns ["src/api/**", "src/server/**", "**/*.ts", "**/*.go"]
  temperature 0.2

  tool_policy {
    read     allow
    write    allow
    edit     allow
    delegate deny
    search   ask
  }

  prompt_append "Focus on API contracts, data integrity, and backwards compatibility."
}

# Minimal category — only required field
category minimal-cat {
  patterns ["src/minimal/**"]
}

# ===========================================================================
# Workflows — all step types, all completion methods, all on_reject values,
#             inputs, outputs, display_name, template placeholders
# ===========================================================================

workflow comprehensive {
  description "Exercises every step type, completion method, and on_reject value"
  version 1

  # autonomous + agent_signal (bare identifier completion) + outputs
  step auto-signal {
    name "Autonomous step with agent_signal"
    type autonomous
    agent bare
    prompt "Perform autonomous work for: {{instance.goal}}"
    completion agent_signal
    outputs [
      { name "work_result" description "Artifact produced by autonomous work" }
    ]
  }

  # interactive + user_confirm (bare identifier completion) + inputs
  step interactive-confirm {
    name "Interactive step with user_confirm"
    type interactive
    agent orchestrator
    prompt "Review the result at {{artifacts.work_result}} for: {{instance.goal}}"
    completion user_confirm
    inputs [
      { name "work_result" description "Artifact to review" }
    ]
  }

  # autonomous + plan_created (parameterised named-block completion) + outputs
  step create-plan {
    name "Create a named plan"
    type autonomous
    agent specialist
    prompt "Plan the implementation of: {{instance.goal}}"
    completion plan_created {
      plan_name "{{instance.slug}}"
    }
    outputs [
      { name "plan_path" description "Path to the generated plan file" }
    ]
  }

  # autonomous + plan_complete (parameterised named-block completion)
  #             + inputs + outputs
  step execute-plan {
    name "Execute the named plan"
    type autonomous
    agent hybrid
    prompt "Execute the plan at {{artifacts.plan_path}} for: {{instance.goal}}"
    completion plan_complete {
      plan_name "{{instance.slug}}"
    }
    inputs [
      { name "plan_path" description "Plan to execute" }
    ]
    outputs [
      { name "impl_path" description "Path to the finished implementation" }
    ]
  }

  # gate + review_verdict + on_reject pause + inputs
  step gate-pause {
    name "Security gate — pause on reject"
    type gate
    agent orchestrator
    prompt "Audit the implementation at {{artifacts.impl_path}} for: {{instance.goal}}"
    completion review_verdict
    on_reject pause
    inputs [
      { name "impl_path" description "Implementation to audit" }
    ]
  }

  # gate + review_verdict + on_reject fail
  step gate-fail {
    name "Compliance gate — fail on reject"
    type gate
    agent specialist
    prompt "Compliance check for: {{instance.goal}}"
    completion review_verdict
    on_reject fail
  }

  # gate + review_verdict + on_reject retry
  step gate-retry {
    name "Quality gate — retry on reject"
    type gate
    agent hybrid
    prompt "Final quality approval for: {{instance.goal}}"
    completion review_verdict
    on_reject retry
  }
}

# Minimal workflow — version + single step only
workflow minimal {
  version 1

  step only-step {
    name "The only step"
    type autonomous
    agent bare
    prompt "Do the thing."
    completion agent_signal
  }
}

# ===========================================================================
# Disable directives — agents, hooks, and skills
# ===========================================================================

disable agents ["legacy-agent", "deprecated-bot"]
disable hooks  ["on-session-idle", "on-context-full"]
disable skills ["unused-skill"]

# ===========================================================================
# Settings
# ===========================================================================

log_level DEBUG
