{
  "name": "@weave",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/engine",
    "packages/adapters/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test --recursive",
    "typecheck": "tsc --noEmit -p tsconfig.json && bun run --filter '*' typecheck",
    "lint": "biome lint packages/",
    "clean": "find . -type d -name dist -not -path '*/node_modules/*' | xargs rm -rf",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "bun-types": "latest",
    "husky": "^9.1.7",
    "typescript": "^5.4.5"
  }
}
