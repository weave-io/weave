---
/**
 * WorkflowGraph — the prototype `.diagram` block + its compiled-graph SVG script.
 *
 * Source of truth: prototype `docs-article.html` (`<div class="diagram">`,
 * lines 155-158, and the compiled-graph `<script>`, lines 276-317). The script
 * builds an SVG figure into `#graphFig` showing an ordered workflow with a
 * planning step, implementation step, and explicit review gate.
 *
 * The script is carried in an Astro `.astro` component (rather than an inline
 * MDX `<script>`) because MDX parses raw `<script>` bodies as JSX expressions,
 * which breaks on plain JavaScript like `document.getElementById(...)`. Astro
 * components emit the script verbatim, matching the prototype behavior. The
 * `.diagram` / `.fig` / `.cap` styling is provided by the shared `docs.css`.
 */
---

<div class="diagram">
  <div class="fig" id="graphFig"></div>
  <div class="cap">
    fig.1 — ordered workflow · plan before implementation · review gate before completion
  </div>
</div>

<script is:inline>
  (function () {
    var fig = document.getElementById('graphFig');
    if (!fig) return;
    var W = 880,
      H = 300;
    function defs() {
      return (
        '<defs><marker id="ah" markerWidth="9" markerHeight="9" refX="7" refY="3.2" orient="auto">' +
        '<path d="M0 0L7 3.2L0 6.4" fill="none" stroke="var(--text-3)" stroke-width="1.3"/></marker>' +
        '<linearGradient id="gfa" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="var(--cyan)"/><stop offset="0.5" stop-color="var(--primary)"/><stop offset="1" stop-color="var(--secondary)"/></linearGradient></defs>'
      );
    }
    function node(x, y, w, h, label, sub, accent) {
      var st = accent || 'var(--border-strong)';
      var fill = accent
        ? 'color-mix(in oklab, ' + accent + ' 14%, var(--bg-elev-1))'
        : 'var(--bg-elev-1)';
      return (
        '<g><rect x="' +
        x +
        '" y="' +
        y +
        '" width="' +
        w +
        '" height="' +
        h +
        '" rx="7" fill="' +
        fill +
        '" stroke="' +
        st +
        '" stroke-width="1.2"/>' +
        '<text x="' +
        (x + w / 2) +
        '" y="' +
        (y + h / 2 - 2) +
        '" text-anchor="middle" font-family="var(--font-mono)" font-size="13" fill="var(--text)">' +
        label +
        '</text>' +
        '<text x="' +
        (x + w / 2) +
        '" y="' +
        (y + h / 2 + 15) +
        '" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--text-4)">' +
        sub +
        '</text></g>'
      );
    }
    function edge(x1, y1, x2, y2) {
      var mx = (x1 + x2) / 2;
      return (
        '<path d="M' +
        x1 +
        ' ' +
        y1 +
        ' C' +
        mx +
        ' ' +
        y1 +
        ',' +
        mx +
        ' ' +
        y2 +
        ',' +
        (x2 - 9) +
        ' ' +
        y2 +
        '" fill="none" stroke="var(--border-strong)" stroke-width="1.4" marker-end="url(#ah)"/>'
      );
    }
    var s = defs();
    var nw = 120,
      nh = 52,
      y0 = 124;
    var xs = [24, 190, 356, 540];
    s += edge(xs[0] + nw, y0 + nh / 2, xs[1], y0 + nh / 2);
    s += edge(xs[1] + nw, y0 + nh / 2, xs[2], y0 + nh / 2);
    s += edge(xs[2] + nw, y0 + nh / 2, xs[3], y0 + nh / 2);
    s += node(xs[0], y0, nw, nh, 'context', 'collect');
    s += node(xs[1], y0, nw, nh, 'plan', 'role planning');
    s += node(xs[2], y0, nw, nh, 'implement', 'agent signal', 'var(--primary)');
    s += node(xs[3], y0, nw, nh, 'review', 'gate', 'var(--secondary)');
    var rx = 706;
    s += node(rx, 44, 150, 44, 'approve', 'review verdict');
    s += node(rx, 196, 150, 44, 'pause', 'on reject');
    s += edge(rx, 66, xs[3] + nw, y0 + 6);
    s += edge(rx, 218, xs[3] + nw, y0 + nh - 6);
    s +=
      '<text x="781" y="120" text-anchor="middle" font-family="var(--font-mono)" font-size="18" fill="var(--text-3)">+</text>';
    fig.innerHTML = '<svg viewBox="0 0 ' + W + ' ' + H + '">' + s + '</svg>';
  })();
</script>
