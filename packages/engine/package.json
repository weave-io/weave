{
  "name": "@weave/engine",
  "version": "0.0.1",
  "description": "Weave orchestration engine: agent runner, hooks, skills, and background manager",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "bun test ./src/__tests__",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@weave/core": "workspace:*",
    "kysely": "^0.27.5",
    "mustache": "^4.2.0",
    "neverthrow": "^8.2.0",
    "pino": "^9.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mustache": "^4.2.6",
    "typescript": "^5.4.5"
  }
}
